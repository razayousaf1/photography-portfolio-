# =============================================================================
# SHAMMAQ BIN FAISAL PHOTOGRAPHY — ENVIRONMENT VARIABLES
# Copy this file to .env.local for local dev, and add the same keys to
# Vercel Project Settings → Environment Variables for production.
# All values below are DUMMY placeholders — replace before deploying.
# =============================================================================

# --- Supabase -----------------------------------------------------------
# Project Settings → API in your Supabase dashboard
NEXT_PUBLIC_SUPABASE_URL=https://dummyproject.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=dummy-anon-key-eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9
# Server-only, used by API routes for privileged writes (never expose to client)
SUPABASE_SERVICE_ROLE_KEY=dummy-service-role-key-eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9

# --- Cloudinary -----------------------------------------------------------
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=dummy-cloud-name
CLOUDINARY_API_KEY=123456789012345
CLOUDINARY_API_SECRET=dummy-cloudinary-api-secret
CLOUDINARY_UPLOAD_FOLDER=shammaq-portfolio

# --- App -----------------------------------------------------------------
# Public site URL, used for metadata/OG tags and absolute links
NEXT_PUBLIC_SITE_URL=https://shammaqbinfaisalxyz.com

# Owner email allow-listed to access /admin (extra defense-in-depth check
# alongside Supabase RLS — see middleware.ts)
OWNER_EMAIL=xyz@shammaqbinfaisal.com
